  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes cc-1errn {=20
  0% { opacity: 0; }
  50% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes cc-7knmf {=20
  0% { opacity: 1; transform: scale(1); }
  100% { opacity: 0; transform: scale(2); }
}

