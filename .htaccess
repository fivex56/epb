# Energy Price Board — Cache & Performance
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — 1 hour (prices update hourly)
  ExpiresByType text/html "access plus 1 hour"

  # JSON data files — 5 minutes (fresh prices)
  ExpiresByType application/json "access plus 300 seconds"

  # Images / logos — 1 year (rarely change)
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # CSS & JS — 1 day
  ExpiresByType text/css "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"

  # Fonts — 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/json application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
